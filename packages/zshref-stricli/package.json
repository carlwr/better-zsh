{
  "name": "@carlwr/zshref-stricli",
  "description": "Experimental stricli variant of @carlwr/zshref — used to compare help output rendering between cliffy and Bloomberg stricli.",
  "version": "0.0.0-exp.0",
  "license": "MIT",
  "private": true,
  "keywords": [
    "zsh",
    "shell",
    "reference",
    "cli",
    "docs",
    "experimental"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/carlwr/better-zsh"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "zshref-stricli": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "prebuild": "[ -n \"$BZ_SKIP_UPSTREAM\" ] || (pnpm --filter @carlwr/zsh-core build && pnpm --filter @carlwr/zsh-core-tooldef build)",
    "pretypecheck": "[ -n \"$BZ_SKIP_UPSTREAM\" ] || (pnpm --filter @carlwr/zsh-core build && pnpm --filter @carlwr/zsh-core-tooldef build)",
    "pretest": "[ -n \"$BZ_SKIP_UPSTREAM\" ] || (pnpm --filter @carlwr/zsh-core build && pnpm --filter @carlwr/zsh-core-tooldef build)",
    "build": "tsx build.ts",
    "watch": "tsx build.ts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@carlwr/zsh-core": "workspace:*",
    "@carlwr/zsh-core-tooldef": "workspace:*",
    "@stricli/core": "^1.2.6"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
