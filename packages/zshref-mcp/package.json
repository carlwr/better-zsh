{
  "name": "@carlwr/zshref-mcp",
  "description": "Structured zsh reference as MCP tools — classify and look up shell options, builtins, parameters, operators, and more. Static data only: no execution, no environment access.",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlwr/better-zsh"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "zshref-mcp": "./dist/server.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "deno.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js",
      "default": "./dist/server.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "[ -n \"$BZ_SKIP_UPSTREAM\" ] || (pnpm --filter @carlwr/zsh-core build && pnpm --filter @carlwr/zsh-core-tooldef build)",
    "pretypecheck": "[ -n \"$BZ_SKIP_UPSTREAM\" ] || (pnpm --filter @carlwr/zsh-core build && pnpm --filter @carlwr/zsh-core-tooldef build)",
    "pretest": "[ -n \"$BZ_SKIP_UPSTREAM\" ] || (pnpm --filter @carlwr/zsh-core build && pnpm --filter @carlwr/zsh-core-tooldef build)",
    "build": "tsx build.ts && node scripts/build-api.mjs",
    "watch": "tsx build.ts --watch",
    "jsrREGISTRY:dry": "pnpm dlx jsr publish --dry-run --allow-dirty",
    "jsrREGISTRY:check": "deno publish --dry-run --allow-dirty",
    "typecheck": "tsc --noEmit",
    "format": "biome check --error-on-warnings --write index.ts server.ts build.ts deno.json scripts src tsconfig.build.json tsconfig.json vitest.config.ts package.json",
    "lint": "biome check --error-on-warnings index.ts server.ts build.ts deno.json scripts src tsconfig.build.json tsconfig.json vitest.config.ts package.json",
    "check": "pnpm typecheck && pnpm lint",
    "test": "vitest run",
    "test:smoke": "pnpm build && node scripts/test-smoke.mjs",
    "testREGISTRY:install": "pnpm build && node scripts/test-install.mjs",
    "test:integration": "pnpm build && export BZ_SKIP_UPSTREAM=1 && pnpm run check && pnpm run test && pnpm run test:smoke",
    "test:integration:act": "ACT_JOB=mcp ../../scripts/test-integration-act",
    "verifyREGISTRY": "pnpm run testREGISTRY:install && pnpm run jsrREGISTRY:check"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@carlwr/zsh-core": "workspace:*",
    "@carlwr/zsh-core-tooldef": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
