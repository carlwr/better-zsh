{
  "name": "@carlwr/zshref",
  "description": "CLI over @carlwr/zsh-core-tooldef — each declarative tool exposed as a cliffy subcommand emitting JSON on stdout.",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlwr/better-zsh"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "zshref": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "deno.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "[ -n \"$BZ_SKIP_UPSTREAM\" ] || (pnpm --filter @carlwr/zsh-core build && pnpm --filter @carlwr/zsh-core-tooldef build)",
    "pretypecheck": "[ -n \"$BZ_SKIP_UPSTREAM\" ] || (pnpm --filter @carlwr/zsh-core build && pnpm --filter @carlwr/zsh-core-tooldef build)",
    "pretest": "[ -n \"$BZ_SKIP_UPSTREAM\" ] || (pnpm --filter @carlwr/zsh-core build && pnpm --filter @carlwr/zsh-core-tooldef build)",
    "build": "tsx build.ts && node scripts/build-api.mjs",
    "watch": "tsx build.ts --watch",
    "jsr:dry": "pnpm dlx jsr publish --dry-run --allow-dirty",
    "jsr:check": "deno publish --dry-run --allow-dirty",
    "typecheck": "tsc --noEmit",
    "format": "biome check --error-on-warnings --write index.ts bin.ts build.ts deno.json scripts src tsconfig.build.json tsconfig.json vitest.config.ts package.json",
    "lint": "biome check --error-on-warnings index.ts bin.ts build.ts deno.json scripts src tsconfig.build.json tsconfig.json vitest.config.ts package.json",
    "check": "pnpm typecheck && pnpm lint",
    "test": "vitest run",
    "test:smoke": "pnpm build && node scripts/test-smoke.mjs",
    "test:install": "pnpm build && node scripts/test-install.mjs",
    "test:integration": "pnpm build && export BZ_SKIP_UPSTREAM=1 && pnpm run check && pnpm run test && pnpm run test:smoke",
    "verify:published": "pnpm run test:install && pnpm run jsr:check"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@carlwr/zsh-core": "workspace:*",
    "@carlwr/zsh-core-tooldef": "workspace:*",
    "@jsr/cliffy__command": "^1.0.0"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
