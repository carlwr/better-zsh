#!/usr/bin/env sh

# Caller is responsible for having built the extension + upstream deps.
# Aggregator scripts (`vsix`, `test:smoke`, `testINTERACTIVE:electron-bundled`,
# `vscode:publish*`, `ovsx:publish*`) run `pnpm build` before invoking this
# script; the leading build triggers the `prebuild` hook that builds
# upstream packages.

set -eu

out=${1:-better-zsh.vsix}

if [ "${1:-}" = -- ]; then
	shift
	out=${1:-better-zsh.vsix}
fi

node scripts/check-package.mjs
pnpm exec vsce package --no-dependencies --out "$out"
