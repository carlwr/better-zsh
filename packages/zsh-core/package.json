{
  "name": "zsh-core",
  "description": "Structured zsh reference data parsed from official zsh documentation + analysis APIs",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlwr/better-zsh"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "deno.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./render": {
      "types": "./dist/types/render.d.ts",
      "import": "./dist/render.mjs",
      "require": "./dist/render.js",
      "default": "./dist/render.mjs"
    },
    "./exec": {
      "types": "./dist/types/exec.d.ts",
      "import": "./dist/exec.mjs",
      "require": "./dist/exec.js",
      "default": "./dist/exec.mjs"
    },
    "./assets": {
      "types": "./dist/types/assets.d.ts",
      "import": "./dist/assets.mjs",
      "require": "./dist/assets.js",
      "default": "./dist/assets.mjs"
    },
    "./data/index.json": "./dist/json/index.json",
    "./data/options.json": "./dist/json/options.json",
    "./data/cond-ops.json": "./dist/json/cond-ops.json",
    "./data/builtins.json": "./dist/json/builtins.json",
    "./data/shell-params.json": "./dist/json/shell-params.json",
    "./data/precmds.json": "./dist/json/precmds.json",
    "./data/redirections.json": "./dist/json/redirections.json",
    "./data/reserved-words.json": "./dist/json/reserved-words.json",
    "./data/subscript-flags.json": "./dist/json/subscript-flags.json",
    "./data/param-flags.json": "./dist/json/param-flags.json",
    "./data/history.json": "./dist/json/history.json",
    "./data/glob-operators.json": "./dist/json/glob-operators.json",
    "./data/glob-flags.json": "./dist/json/glob-flags.json",
    "./data/process-substs.json": "./dist/json/process-substs.json",
    "./data/prompt-escapes.json": "./dist/json/prompt-escapes.json",
    "./data/zle-widgets.json": "./dist/json/zle-widgets.json",
    "./schema/index.schema.json": "./dist/schema/index.schema.json",
    "./schema/options.schema.json": "./dist/schema/options.schema.json",
    "./schema/cond-ops.schema.json": "./dist/schema/cond-ops.schema.json",
    "./schema/builtins.schema.json": "./dist/schema/builtins.schema.json",
    "./schema/shell-params.schema.json": "./dist/schema/shell-params.schema.json",
    "./schema/precmds.schema.json": "./dist/schema/precmds.schema.json",
    "./schema/redirections.schema.json": "./dist/schema/redirections.schema.json",
    "./schema/reserved-words.schema.json": "./dist/schema/reserved-words.schema.json",
    "./schema/subscript-flags.schema.json": "./dist/schema/subscript-flags.schema.json",
    "./schema/param-flags.schema.json": "./dist/schema/param-flags.schema.json",
    "./schema/history.schema.json": "./dist/schema/history.schema.json",
    "./schema/glob-operators.schema.json": "./dist/schema/glob-operators.schema.json",
    "./schema/glob-flags.schema.json": "./dist/schema/glob-flags.schema.json",
    "./schema/process-substs.schema.json": "./dist/schema/process-substs.schema.json",
    "./schema/prompt-escapes.schema.json": "./dist/schema/prompt-escapes.schema.json",
    "./schema/zle-widgets.schema.json": "./dist/schema/zle-widgets.schema.json",
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.mjs",
      "require": "./dist/internal.js",
      "default": "./dist/internal.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsx build.ts && node scripts/build-api.mjs && tsx scripts/build-schema.ts",
    "watch": "tsx build.ts --watch",
    "docs:typedoc:html": "typedoc",
    "docs:typedoc:json": "typedoc --emit none",
    "docs:api": "node scripts/build-api.mjs",
    "docs:build": "pnpm build && pnpm docs:typedoc:html && node scripts/build-docs.mjs",
    "jsr:dry": "pnpm dlx jsr publish --dry-run --allow-dirty",
    "jsr:check": "deno publish --dry-run --allow-dirty",
    "typecheck": "tsc --noEmit",
    "format": "biome check --error-on-warnings --write assets.ts build.ts deno.json exec.ts index.ts internal.ts render.ts scripts src tsconfig.build.json tsconfig.json typedoc.json vitest.config.ts package.json",
    "lint": "biome check --error-on-warnings assets.ts build.ts deno.json exec.ts index.ts internal.ts render.ts scripts src tsconfig.build.json tsconfig.json typedoc.json vitest.config.ts package.json",
    "check": "pnpm typecheck && pnpm lint",
    "test": "vitest run",
    "test:smoke": "pnpm build && tsx scripts/test-smoke.ts && pnpm run jsr:check",
    "test:integration": "pnpm run check && pnpm run test && pnpm run test:smoke && pnpm run jsr:check"
  },
  "dependencies": {
    "@carlwr/typescript-extra": "0.7.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ts-json-schema-generator": "^2.4.0",
    "vitest": "^4.1.2"
  }
}
