{
	"name": "better-zsh",
	"displayName": "Better Zsh",
	"description": "improved word boundary handling for zsh files in VS Code",
	"author": {
		"name": "carlwr",
		"url": "https://github.com/carlwr"
	},
	"publisher": "carlwr",
	"version": "0.0.1",
	"license": "MIT",
	"packageManager": "pnpm@10.23.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/carlwr/vscode-better-zsh"
	},
	"engines": {
		"vscode": "^1.96.0"
	},
	"categories": [
		"Programming Languages"
	],
	"main": "./out/extension.js",
	"activationEvents": [
		"onLanguage:zsh"
	],
	"contributes": {
		"languages": [
			{
				"id": "zsh",
				"aliases": [
					"Zsh",
					"zsh"
				],
				"extensions": [
					".zsh",
					".zshrc",
					".zprofile",
					".zlogin",
					".zlogout",
					".zshenv",
					".zsh-theme"
				],
				"filenames": [
					"zshrc",
					"zshenv",
					"zlogin",
					"zprofile",
					"zlogout"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "zsh",
				"scopeName": "source.shell.zsh",
				"path": "./syntaxes/shell-unix-bash.tmLanguage.json"
			}
		],
		"semanticTokenScopes": [
			{
				"language": "zsh",
				"scopes": {
					"function.defaultLibrary": [
						"support.function.builtin.shell"
					]
				}
			}
		]
	},
	"scripts": {
		"build": "tsx build.ts",
		"watch": "tsx build.ts --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check",
		"check": "pnpm typecheck && pnpm lint",
		"test": "vitest run",
		"test:integration": "scripts/test-integration-act",
		"testINTERACTIVE:electron": "tsc && scripts/testINTERACTIVE-electron",
		"testINTERACTIVE:electron-bundled": "scripts/package-vsix ./better-zsh.vsix && tsc && scripts/testINTERACTIVE-bundled",
		"vsix": "pnpm check && pnpm test && scripts/package-vsix ./better-zsh.vsix",
		"test:smoke": "pnpm check && pnpm test && scripts/package-vsix /tmp/better-zsh-smoke.vsix && rm /tmp/better-zsh-smoke.vsix && echo 'smoke: OK'",
		"vscode:publish:dry": "pnpm check && pnpm test && pnpm build && pnpm exec vsce ls --no-dependencies && echo '---\n(DRY-RUN; ran vsce ls above.)'",
		"vscode:publish": "pnpm check && pnpm test && pnpm build && pnpm exec vsce publish --no-dependencies",
		"ovsx:publish:dry": "pnpm check && pnpm test && pnpm build && pnpm exec vsce ls --no-dependencies && echo '---\n(DRY-RUN for open-vsx; ran vsce ls above.)'",
		"ovsx:publish": "pnpm check && pnpm test && pnpm build && npx -y ovsx -p $OPEN_VSX_TOKEN publish --no-dependencies",
		"LAST_dummy": ""
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@carlwr/fastcheck-utils": "^0.5.0",
		"@carlwr/typescript-extra": "0.6.1",
		"@fast-check/vitest": "^0.4.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.15.0",
		"@types/vscode": "1.96.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.7.1",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.8.0",
		"vitest": "^4.1.2",
		"zzz_LAST_dummy": "npm:empty-npm-package@1.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@vscode/vsce-sign",
			"esbuild",
			"keytar"
		]
	}
}
