{
  "name": "better-zsh-workspace",
  "private": true,
  "version": "0.0.1",
  "license": "MIT",
  "packageManager": "pnpm@10.23.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlwr/better-zsh"
  },
  "scripts": {
    "build": "pnpm --filter better-zsh build",
    "watch": "pnpm --filter better-zsh watch",
    "format": "pnpm -r --filter './packages/*' --if-present format",
    "typecheck": "pnpm -r --filter './packages/*' --if-present typecheck",
    "lint": "pnpm -r --filter './packages/*' --if-present lint",
    "check": "pnpm -r --filter './packages/*' --if-present check",
    "test": "pnpm -r --filter './packages/*' --if-present test",
    "test:integration": "scripts/test-integration-act",
    "dump:refs": "pnpm --filter better-zsh dump:refs",
    "testINTERACTIVE": "pnpm run testINTERACTIVE:electron && pnpm run testINTERACTIVE:electron-bundled",
    "testINTERACTIVE:electron": "pnpm --filter better-zsh testINTERACTIVE:electron",
    "testINTERACTIVE:electron-bundled": "pnpm --filter better-zsh testINTERACTIVE:electron-bundled",
    "vsix": "pnpm --filter better-zsh vsix",
    "test:smoke": "pnpm --filter zsh-core test:smoke && pnpm --filter better-zsh test:smoke",
    "docs:zsh-core": "pnpm --filter zsh-core docs:build",
    "jsr:zsh-core:dry": "pnpm --filter zsh-core jsr:dry",
    "jsr:zsh-core:check": "pnpm --filter zsh-core jsr:check",
    "vscode:publish:dry": "pnpm --filter better-zsh vscode:publish:dry",
    "vscode:publish": "pnpm --filter better-zsh vscode:publish",
    "ovsx:publish:dry": "pnpm --filter better-zsh ovsx:publish:dry",
    "ovsx:publish": "pnpm --filter better-zsh ovsx:publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@carlwr/fastcheck-utils": "^0.5.0",
    "@carlwr/typescript-extra": "0.7.0",
    "@fast-check/vitest": "^0.4.0",
    "@microsoft/api-extractor": "^7.58.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.0",
    "@types/vscode": "1.96.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "fast-check": "^4.6.0",
    "jsonc-parser": "^3.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2",
    "zod": "^4.3.6",
    "zzz_LAST_dummy": "npm:empty-npm-package@1.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "esbuild",
      "keytar"
    ]
  }
}
